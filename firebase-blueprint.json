{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile and business settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "businessName": { "type": "string" },
        "gstin": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "bankDetails": {
          "type": "object",
          "properties": {
            "bankName": { "type": "string" },
            "accountNumber": { "type": "string" },
            "ifsc": { "type": "string" },
            "upiId": { "type": "string" }
          }
        },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "plan"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer details for a business",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "businessName": { "type": "string" },
        "gstin": { "type": "string" },
        "address": { "type": "string" },
        "state": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "businessId", "name", "phone", "state"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "GST compliant invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "businessId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "items": { "type": "array", "items": { "type": "object" } },
        "subtotal": { "type": "number" },
        "cgst": { "type": "number" },
        "sgst": { "type": "number" },
        "igst": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "partial"] },
        "gstType": { "type": "string", "enum": ["CGST_SGST", "IGST"] },
        "confirmedByUser": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "invoiceNumber", "businessId", "customerId", "customerName", "date", "total", "status", "gstType", "confirmedByUser"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoice records"
    }
  }
}
